---
import { getCollection, type CollectionEntry } from "astro:content";
import Card from "../../components/Card.astro";
import Layout from "../../layouts/Layout.astro";

const posts: CollectionEntry<"blog">[] = await getCollection("blog", ({ id }: { id: string }) => id.startsWith("es/"));
---

<Layout title="Inicio">
	<section class="hero">
		<p class="eyebrow">Conquer Blog</p>
		<h1>Ideas practicas para crear productos web solidos</h1>
		<p>
			Publicamos guias de Astro, arquitectura frontend y buenas practicas de desarrollo para equipos
			que quieren enviar software de calidad con rapidez.
		</p>
		<div class="actions">
			<a class="button-link" href="/es/blog/">Ver todos los articulos</a>
			<a class="ghost" href="/es/about/">Conocer el proyecto</a>
		</div>
	</section>

	<section>
		<h2>Ultimos articulos</h2>
		<p>Una seleccion reciente con contenido tecnico y ejemplos aplicables desde hoy.</p>
		<div class="posts-grid">
			{
				posts.map((post) => {
					return <Card {...post.data} slug={post.slug.replace(/^es\//, "")} />;
				})
			}
		</div>
	</section>

	<section class="pillars">
		<h2>Que vas a encontrar aqui</h2>
		<ul>
			<li>Guias paso a paso para Astro y su sistema de contenido.</li>
			<li>Estrategias de internacionalizacion para proyectos reales.</li>
			<li>Patrones de UI para pasar de demo a producto.</li>
		</ul>
	</section>
</Layout>

<style>
	.hero {
		display: grid;
		gap: 0.9rem;
		background: linear-gradient(140deg, rgba(15, 118, 110, 0.14), rgba(220, 107, 47, 0.12));
	}

	.eyebrow {
		margin: 0;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		font-size: 0.84rem;
	}

	.actions {
		display: flex;
		gap: 0.65rem;
		flex-wrap: wrap;
	}

	.ghost {
		display: inline-flex;
		align-items: center;
		padding: 0.62rem 0.95rem;
		border-radius: 999px;
		border: 1px solid var(--line);
		background: rgba(255, 255, 255, 0.7);
		font-weight: 700;
	}

	.posts-grid {
		display: grid;
		gap: 0.8rem;
		margin-top: 0.6rem;
	}

	.pillars ul {
		margin: 0.5rem 0 0;
	}
</style>
